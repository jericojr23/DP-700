{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "outDir": ".tsbuild/node"
  },
  "include": ["vite.config.ts", "scripts/**/*.mjs"]
}
